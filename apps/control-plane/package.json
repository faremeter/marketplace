{
  "name": "control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:wallets": "tsx src/scripts/migrate-wallets.ts",
    "audit:regex": "tsx src/scripts/audit-regex-endpoints.ts",
    "test": "tap 'src/**/*.test.ts'",
    "test:watch": "tap 'src/**/*.test.ts' --watch"
  },
  "tap": {
    "plugin": [
      "!@tapjs/typescript",
      "@tapjs/tsx"
    ]
  },
  "dependencies": {
    "@1click/db-schema": "workspace:*",
    "@aws-sdk/client-route-53": "^3.948.0",
    "@faremeter/gateway-nginx": "^0.21.0",
    "@faremeter/info": "^0.21.0",
    "@faremeter/middleware-openapi": "^0.21.0",
    "@hono/arktype-validator": "^2.0.1",
    "@hono/node-server": "^1.19.5",
    "@logtape/logtape": "^1.2.2",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "arktype": "^2.2.0",
    "bcrypt": "^5.1.1",
    "bs58": "^6.0.0",
    "dotenv": "^17.2.1",
    "hono": "^4.9.10",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.4",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "postmark": "^4.0.5",
    "safe-regex2": "^5.0.0",
    "viem": "^2.41.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "bigint-buffer",
      "bufferutil",
      "utf-8-validate"
    ]
  },
  "devDependencies": {
    "@1click/test-db": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@tapjs/asserts": "^4.0.1",
    "@tapjs/tsx": "^3.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.11",
    "@types/pg": "^8.11.10",
    "better-sqlite3": "^11.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tap": "^21.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.48.1"
  }
}
