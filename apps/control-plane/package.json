{
  "name": "control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:wallets": "tsx src/scripts/migrate-wallets.ts",
    "audit:regex": "tsx src/scripts/audit-regex-endpoints.ts",
    "test": "tap 'src/**/*.test.ts'",
    "test:watch": "tap 'src/**/*.test.ts' --watch"
  },
  "tap": {
    "plugin": [
      "!@tapjs/typescript",
      "@tapjs/tsx"
    ]
  },
  "dependencies": {
    "@1click/db-schema": "workspace:*",
    "@aws-sdk/client-route-53": "^3.948.0",
    "@faremeter/gateway-nginx": "catalog:",
    "@faremeter/info": "catalog:",
    "@faremeter/middleware-openapi": "catalog:",
    "@hono/arktype-validator": "^2.0.1",
    "@hono/node-server": "catalog:",
    "@logtape/logtape": "catalog:",
    "@solana-program/token": "catalog:",
    "@solana/kit": "catalog:",
    "arktype": "catalog:",
    "bcrypt": "^5.1.1",
    "bs58": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.4",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "postmark": "^4.0.5",
    "safe-regex2": "^5.0.0",
    "viem": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "bufferutil",
      "utf-8-validate"
    ]
  },
  "devDependencies": {
    "@1click/test-db": "workspace:*",
    "@eslint/js": "catalog:",
    "@tapjs/asserts": "catalog:",
    "@tapjs/tsx": "catalog:",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "better-sqlite3": "^11.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tap": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
