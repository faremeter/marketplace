{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "outDir": "bin",
    "target": "es2020",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "experimentalDecorators": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"],
  "exclude": ["sidecar"]
}
