#!/bin/bash
set -e
DOMAIN=$1

if [ -z "$DOMAIN" ]; then
    echo "Usage: delete-tenant-cert <domain>"
    exit 1
fi

CERT_DIR="/etc/letsencrypt/live/${DOMAIN}"

if [ -d "$CERT_DIR" ]; then
    rm -rf "$CERT_DIR"
    /usr/local/bin/regen-tenant-nginx
    echo "Deleted cert for ${DOMAIN}"
else
    echo "No cert found for ${DOMAIN}"
fi
