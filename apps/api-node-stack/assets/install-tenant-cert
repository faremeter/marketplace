#!/bin/bash
set -e
DOMAIN=$1
FULLCHAIN_B64=$2
PRIVKEY_B64=$3

if [ -z "$DOMAIN" ] || [ -z "$FULLCHAIN_B64" ] || [ -z "$PRIVKEY_B64" ]; then
    echo "Usage: install-tenant-cert <domain> <fullchain_b64> <privkey_b64>"
    exit 1
fi

CERT_DIR="/etc/letsencrypt/live/${DOMAIN}"
mkdir -p "$CERT_DIR"

echo "$FULLCHAIN_B64" | base64 -d > "$CERT_DIR/fullchain.pem"
echo "$PRIVKEY_B64" | base64 -d > "$CERT_DIR/privkey.pem"

chmod 600 "$CERT_DIR/privkey.pem"
chmod 644 "$CERT_DIR/fullchain.pem"

echo "Installed cert for ${DOMAIN}"

/usr/local/bin/regen-tenant-nginx
