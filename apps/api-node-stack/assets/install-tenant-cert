#!/bin/bash
set -euo pipefail

DOMAIN="${1:-}"

if [[ -z "$DOMAIN" ]]; then
    echo "Usage: install-tenant-cert <domain>" >&2
    exit 1
fi

if [[ ! "$DOMAIN" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?(\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)+$ ]]; then
    echo "Invalid domain format" >&2
    exit 1
fi

if [[ "$DOMAIN" == *".."* ]] || [[ "$DOMAIN" == *"/"* ]]; then
    echo "Invalid domain: path traversal attempt" >&2
    exit 1
fi

CERT_DATA=$(cat)
FULLCHAIN=$(echo "$CERT_DATA" | jq -r '.fullchain // empty')
PRIVKEY=$(echo "$CERT_DATA" | jq -r '.privkey // empty')

if [[ -z "$FULLCHAIN" ]] || [[ -z "$PRIVKEY" ]]; then
    echo "Missing certificate data in stdin" >&2
    exit 1
fi

CERT_DIR="/etc/letsencrypt/live/${DOMAIN}"
mkdir -p "$CERT_DIR"

printf '%s' "$FULLCHAIN" >"$CERT_DIR/fullchain.pem"
chmod 644 "$CERT_DIR/fullchain.pem"

printf '%s' "$PRIVKEY" >"$CERT_DIR/privkey.pem"
chmod 640 "$CERT_DIR/privkey.pem"

echo "Installed cert for ${DOMAIN}"

/usr/local/bin/regen-tenant-nginx
